-- GENERATOR ESP

local GeneratorESPActive = false
local GEN_HL_TAG = "SVD_GenHL"
local GEN_BB_TAG = "SVD_GenBB"

local function ClearGeneratorESP()
    for _, obj in ipairs(game:GetService("Workspace"):GetDescendants()) do
        if obj.Name == GEN_HL_TAG or obj.Name == GEN_BB_TAG then
            pcall(function() obj:Destroy() end)
        end
    end
end

local function GetGenerators()
    local gens = {}
    local seen = {}
    local keywords = {"Generator", "generator", "Generat", "generat"}
    for _, obj in ipairs(game:GetService("Workspace"):GetDescendants()) do
        if not seen[obj] then
            for _, kw in ipairs(keywords) do
                if obj.Name:find(kw) and (obj:IsA("BasePart") or obj:IsA("Model")) then
                    seen[obj] = true
                    table.insert(gens, obj)
                    break
                end
            end
        end
    end
    return gens
end

local function GetNearestGenerator()
    local lc = LocalPlayer.Character
    local hrp = lc and lc:FindFirstChild("HumanoidRootPart")
    if not hrp then return nil, nil, math.huge end

    local gens = GetGenerators()
    local nearest, nearestPart, nearestDist = nil, nil, math.huge

    for _, gen in ipairs(gens) do
        local part = gen:IsA("Model")
            and (gen.PrimaryPart or gen:FindFirstChildWhichIsA("BasePart"))
            or gen
        if part then
            local dist = (hrp.Position - part.Position).Magnitude
            if dist < nearestDist then
                nearestDist = dist
                nearest = gen
                nearestPart = part
            end
        end
    end

    return nearest, nearestPart, nearestDist
end

local _currentGenObj  = nil
local _currentGenPart = nil
local _currentGenDist = math.huge

local function RefreshGeneratorESP()
    if not GeneratorESPActive then return end

    local newGen, newPart, newDist = GetNearestGenerator()

    if not newGen then
        ClearGeneratorESP()
        _currentGenObj  = nil
        _currentGenPart = nil
        _currentGenDist = math.huge
        return
    end

    if newGen == _currentGenObj then
        _currentGenDist = newDist
        return
    end

    ClearGeneratorESP()
    _currentGenObj  = newGen
    _currentGenPart = newPart
    _currentGenDist = newDist

    if not newGen:FindFirstChild(GEN_HL_TAG) then
        local hl = Instance.new("Highlight")
        hl.Name = GEN_HL_TAG
        hl.FillColor = Color3.fromRGB(255, 200, 0)
        hl.OutlineColor = Color3.fromRGB(255, 240, 80)
        hl.FillTransparency = 0.45
        hl.OutlineTransparency = 0
        hl.Adornee = newGen
        hl.Parent = newGen
    end

    if not newPart:FindFirstChild(GEN_BB_TAG) then
        local bb = Instance.new("BillboardGui")
        bb.Name = GEN_BB_TAG
        bb.Size = UDim2.new(0, 100, 0, 30)
        bb.StudsOffset = Vector3.new(0, 4, 0)
        bb.AlwaysOnTop = true
        bb.Adornee = newPart
        bb.Parent = newPart

        local lbl = Instance.new("TextLabel")
        lbl.Name = "SVD_GenLbl"
        lbl.Size = UDim2.new(1, 0, 1, 0)
        lbl.BackgroundTransparency = 1
        lbl.Font = Enum.Font.GothamBold
        lbl.TextColor3 = Color3.fromRGB(255, 230, 0)
        lbl.TextStrokeTransparency = 0
        lbl.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)
        lbl.TextSize = 11
        lbl.Text = "Generator"
        lbl.Parent = bb
    end
end

local function ToggleGeneratorESP(state)
    GeneratorESPActive = state

    if Connections.GenESPLoop then
        pcall(function() Connections.GenESPLoop:Disconnect() end)
        Connections.GenESPLoop = nil
    end
    if Connections.GenDistLoop then
        pcall(function() Connections.GenDistLoop:Disconnect() end)
        Connections.GenDistLoop = nil
    end

    if state then
        Connections.GenESPLoop = RunService.Heartbeat:Connect(function()
            if not GeneratorESPActive then return end
            task.wait(2)
            if GeneratorESPActive then RefreshGeneratorESP() end
        end)

        Connections.GenDistLoop = RunService.RenderStepped:Connect(function()
            if not GeneratorESPActive then return end
            if not _currentGenPart or not _currentGenPart.Parent then return end
            local lc = LocalPlayer.Character
            local hrp = lc and lc:FindFirstChild("HumanoidRootPart")
            if not hrp then return end

            local bb = _currentGenPart:FindFirstChild(GEN_BB_TAG)
            if bb then
                local lbl = bb:FindFirstChild("SVD_GenLbl")
                if lbl then
                    local dist = math.floor((hrp.Position - _currentGenPart.Position).Magnitude)
                    lbl.Text = "Generator [" .. dist .. "m]"
                end
            end
        end)

        RefreshGeneratorESP()
        Notif("SIEXTHER VD", "Generator ESP ON", 3)
    else
        ClearGeneratorESP()
        _currentGenObj  = nil
        _currentGenPart = nil
        _currentGenDist = math.huge
        Notif("SIEXTHER VD", "Generator ESP OFF", 2)
    end
end


-- TELEPORT

local function TeleportToSurvivor()
    local lc = LocalPlayer.Character
    if not lc or not lc:FindFirstChild("HumanoidRootPart") then return end
    local tgt, md = nil, math.huge
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and not IsKiller(p) and p.Character
            and p.Character:FindFirstChild("HumanoidRootPart") then
            local d = (lc.HumanoidRootPart.Position - p.Character.HumanoidRootPart.Position).Magnitude
            if d < md then md = d; tgt = p end
        end
    end
    if tgt then
        lc.HumanoidRootPart.CFrame = tgt.Character.HumanoidRootPart.CFrame
        Notif("SIEXTHER VD", "Teleported to " .. tgt.Name, 2)
    else
        Notif("SIEXTHER VD", "No survivor found", 2)
    end
end

